# inferencia — Paste these into Coolify's Environment Variables tab.
# REQUIRED (deployment will fail without these):
INFERENCIA_BACKEND_URL=http://192.168.0.109:11434
INFERENCIA_API_KEYS=sk-your-key-here

# TTS backends (on Mac M4 Max at 192.168.0.109):
INFERENCIA_KOKORO_URL=http://192.168.0.109:50051
INFERENCIA_CHATTERBOX_URL=http://192.168.0.109:50052

# Watchdog configuration:
INFERENCIA_WATCHDOG_INTERVAL=30s
INFERENCIA_WATCHDOG_FAIL_THRESHOLD=3
INFERENCIA_WATCHDOG_TIMEOUT=5s

# OPTIONAL (defaults shown):
# INFERENCIA_HOST=0.0.0.0
# INFERENCIA_PORT=8080
# INFERENCIA_LOG_LEVEL=info
# INFERENCIA_LOG_FORMAT=json
# INFERENCIA_RATELIMIT_RPS=10
# INFERENCIA_RATELIMIT_BURST=20
# INFERENCIA_OTEL_ENABLED=false
# INFERENCIA_OTEL_ENDPOINT=http://localhost:4318
# INFERENCIA_OTEL_SERVICE_NAME=inferencia
