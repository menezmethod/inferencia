# inferencia — Paste these into Coolify's Environment Variables tab.
# REQUIRED (deployment will fail without these):
INFERENCIA_BACKEND_URL=http://192.168.0.x:11434
INFERENCIA_API_KEYS=sk-PASTE_YOUR_KEY_HERE

# OPTIONAL (defaults shown):
# INFERENCIA_LOG_LEVEL=info
# INFERENCIA_LOG_FORMAT=json
# INFERENCIA_RATELIMIT_RPS=10
# INFERENCIA_RATELIMIT_BURST=20
